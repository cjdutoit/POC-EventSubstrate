{
  "skill": "the-standard-practices",
  "version": "1.0.0",
  "branch_naming": {
    "pattern": "users/{handle}/{type}/{short-description}",
    "case": "lowercase-kebab",
    "examples": [
      "users/jsmith/feature/add-student-broker",
      "users/jdoe/bugfix/fix-enrollment-null-check"
    ]
  },
  "commit_format": {
    "pattern": "{CATEGORY}: {Imperative Description}",
    "examples": [
      "BROKERS: Add Student Storage Broker",
      "FOUNDATIONS: Add Student Validation"
    ]
  },
  "forbidden_commit_words": ["fix", "update", "changes", "wip", "temp", "misc"],
  "ci_tooling": ["ADotNet", "GitHub Actions YAML"],
  "pr_target_branch": "main"
}
